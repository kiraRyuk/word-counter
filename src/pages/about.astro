---
import BaseLayout from '@/layouts/BaseLayout.astro'; import ContentPage from '@/components/ContentPage.astro';
const sections = [{title:'Our mission',paragraphs:['Word Counter helps students, writers, educators, and professionals understand their text instantly. We focus on speed, clarity, and accuracy.']},{title:'Privacy first',paragraphs:['Your text is analyzed locally in your browser. We designed the tool so you can work confidently with drafts and documents.']},{title:'Built for real work',paragraphs:['From essays to articles and reports, our straightforward metrics help you meet requirements and improve structure.']} ];
---
