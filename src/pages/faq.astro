---
import BaseLayout from '@/layouts/BaseLayout.astro'; const faqs=[['How does Word Counter count words?','It trims leading and trailing whitespace, then treats one or more whitespace characters as the separator between words.'],['Does Word Counter save my text?','No. The tool analyzes text locally in your browser and does not intentionally send it to our servers.'],['Can I upload a document?','You can upload plain-text .txt files. Support for more formats may be added later.'],['How are sentences counted?','Each period, exclamation mark, or question mark is counted as a sentence ending.'],['Is Word Counter free?','Yes. The tool is free to use and does not require an account.']]; const schema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:faqs.map(([q,a])=>({'@type':'Question',name:q,acceptedAnswer:{'@type':'Answer',text:a}}))};
---
<BaseLayout title="Word Counter FAQ" description="Answers to common questions about word counts, sentence counts, privacy, and uploading text files." path="/faq" schema={schema}><section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24"><h1 class="text-4xl font-bold sm:text-5xl">Frequently asked questions</h1><p class="mt-5 text-lg text-muted">Everything you need to know about using Word Counter.</p><div class="mt-10 space-y-4">{faqs.map(([q,a])=><details class="rounded-2xl border border-line p-5"><summary class="cursor-pointer font-semibold">{q}</summary><p class="mt-3 leading-7 text-muted">{a}</p></details>)}</div></section></BaseLayout>
