---
import BaseLayout from '@/layouts/BaseLayout.astro'; export function getStaticPaths(){return [{params:{slug:'how-to-count-words'},props:{title:'How to Count Words Accurately',intro:'A reliable word count starts with a clear counting rule.',sections:['Most digital counters treat words as groups of characters separated by whitespace. That makes the result predictable even when a draft contains extra spaces or line breaks.','Different schools and publishers may handle hyphenated terms or citations differently. Always check the specific requirements, then use a consistent counter while drafting.']}},{params:{slug:'ideal-blog-post-length'},props:{title:'How Long Should a Blog Post Be?',intro:'The best article length is the length that fully satisfies the reader’s intent.',sections:['Start by defining the question your reader needs answered. A focused answer may need only a few hundred words, while a detailed tutorial may require several thousand.','Review the structure as well as the total: clear paragraphs, useful headings, and direct sentences matter more than padding an article to reach a target.']}}]}; const {title,intro,sections}=Astro.props; const path=`/blog/${Astro.params.slug}`; const schema={'@context':'https://schema.org','@type':'Article',headline:title,datePublished:'2026-06-15',author:{'@type':'Organization',name:'Word Counter'}};
---
<BaseLayout title={`${title} | Word Counter`} description={intro} path={path} schema={schema}><article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24"><a href="/blog" class="text-sm font-semibold text-brand">← Writing tips</a><h1 class="mt-5 text-4xl font-bold sm:text-5xl">{title}</h1><p class="mt-5 text-xl leading-8 text-muted">{intro}</p><div class="mt-10 space-y-6">{sections.map(p=><p class="text-lg leading-8 text-body">{p}</p>)}</div><a href="/#tool" class="mt-10 inline-block rounded-lg bg-brand px-6 py-3 font-semibold text-white">Check your word count</a></article></BaseLayout>
