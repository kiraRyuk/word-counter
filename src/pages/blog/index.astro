---
import BaseLayout from '@/layouts/BaseLayout.astro'; const posts=[{slug:'how-to-count-words',title:'How to Count Words Accurately',copy:'Understand common word-count rules and avoid surprises in your next assignment.'},{slug:'ideal-blog-post-length',title:'How Long Should a Blog Post Be?',copy:'Use purpose and reader intent—not a magic number—to choose the right length.'}];
---
<BaseLayout title="Writing Tips Blog" description="Practical guides about word counts, content length, and clearer writing." path="/blog"><section class="mx-auto max-w-content px-4 py-16 sm:px-6 sm:py-24"><h1 class="text-4xl font-bold sm:text-5xl">Writing tips</h1><p class="mt-5 text-lg text-muted">Practical advice for clearer, more intentional writing.</p><div class="mt-10 grid gap-5 sm:grid-cols-2">{posts.map(post=><article class="rounded-2xl border border-line p-6"><p class="text-sm font-semibold text-brand">Writing guide</p><h2 class="mt-3 text-2xl font-semibold"><a href={`/blog/${post.slug}`}>{post.title}</a></h2><p class="mt-3 leading-7 text-muted">{post.copy}</p><a class="mt-5 inline-block font-semibold underline" href={`/blog/${post.slug}`}>Read guide</a></article>)}</div></section></BaseLayout>
