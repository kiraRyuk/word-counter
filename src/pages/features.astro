---
import BaseLayout from '@/layouts/BaseLayout.astro';
const features=[['Instant word count','Measure whitespace-separated words as you type or paste.'],['Complete character totals','Compare characters with and without whitespace.'],['Structure at a glance','Review sentence and paragraph counts instantly.'],['Plain-text upload','Open .txt files directly in the private browser-based editor.'],['Copy and reset','Copy your revised text or clear everything in one click.'],['Private by design','Your writing stays in your browser while it is analyzed.']];
---
<BaseLayout title="Word Counter Features" description="Explore fast, private word count, character count, sentence count, paragraph count, and text file upload features." path="/features"><section class="mx-auto max-w-content px-4 py-16 sm:px-6 sm:py-24"><p class="text-sm font-bold uppercase tracking-widest text-brand">Simple and capable</p><h1 class="mt-4 text-4xl font-bold sm:text-5xl">Features built for focused writing</h1><p class="mt-5 max-w-2xl text-lg text-muted">Get the essential measurements you need without sending your draft to a server or learning a complicated interface.</p><div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{features.map(([title,copy])=><article class="rounded-2xl border border-line p-6"><span class="grid size-10 place-items-center rounded-full bg-brand text-white">✓</span><h2 class="mt-5 text-lg font-semibold">{title}</h2><p class="mt-2 leading-6 text-muted">{copy}</p></article>)}</div><a href="/#tool" class="mt-10 inline-block rounded-lg bg-brand px-6 py-3 font-semibold text-white">Try Word Counter</a></section></BaseLayout>
