---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Us" description="Contact the Word Counter team with questions, feedback, or feature ideas." path="/contact"><section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24"><h1 class="text-4xl font-bold sm:text-5xl">Contact Us</h1><p class="mt-5 text-lg text-muted">Have feedback or a feature idea? We would love to hear from you.</p><form class="mt-10 space-y-5 rounded-2xl border border-line p-6" action="mailto:hello@wordcounter.example" method="post" enctype="text/plain"><label class="block font-medium">Name<input required name="name" class="mt-2 min-h-12 w-full rounded-lg border border-line px-4" /></label><label class="block font-medium">Email<input required type="email" name="email" class="mt-2 min-h-12 w-full rounded-lg border border-line px-4" /></label><label class="block font-medium">Message<textarea required name="message" class="mt-2 min-h-40 w-full rounded-lg border border-line p-4"></textarea></label><button class="rounded-lg bg-brand px-6 py-3 font-semibold text-white" type="submit">Send message</button></form></section></BaseLayout>
