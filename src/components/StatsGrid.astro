---
import StatsCard from './StatsCard.astro';
---
<section aria-labelledby="statistics-title">
  <h2 id="statistics-title" class="mb-4 text-xl font-semibold">Text statistics</h2>
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5" aria-live="polite" aria-atomic="true">
    <StatsCard label="Words" valueId="words" featured />
    <StatsCard label="Characters" valueId="characters" />
    <StatsCard label="Characters (No Spaces)" valueId="charactersNoSpaces" />
    <StatsCard label="Sentences" valueId="sentences" />
    <StatsCard label="Paragraphs" valueId="paragraphs" />
  </div>
</section>
