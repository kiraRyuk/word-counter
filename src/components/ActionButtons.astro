<div class="flex flex-col gap-3 sm:flex-row">
  <button id="clear-text" type="button" class="min-h-12 rounded-lg bg-brand px-6 py-3 font-medium text-white transition-colors hover:bg-brand-active">
    Clear text
  </button>
  <button id="copy-text" type="button" class="min-h-12 rounded-lg border border-ink bg-white px-6 py-3 font-medium text-ink transition-colors hover:bg-soft">
    Copy text
  </button>
  <p id="action-status" class="self-center text-sm text-muted" aria-live="polite"></p>
</div>
