<label for="text-input" class="mb-3 block text-base font-semibold text-ink">Type or paste your text</label>
<textarea id="text-input" class="min-h-80 w-full resize-y rounded-[14px] border border-line bg-white p-5 text-base leading-7 text-body placeholder:text-muted focus:border-ink focus:outline-2" placeholder="Start writing or paste your text here..." spellcheck="true" aria-describedby="editor-help error-message"></textarea>
<p id="editor-help" class="mt-2 text-sm text-muted">Statistics update automatically as you write.</p>
<p id="error-message" class="mt-3 hidden rounded-lg bg-red-50 px-4 py-3 text-sm font-medium text-[#c13515]" role="alert"></p>
