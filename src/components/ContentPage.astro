---
interface Props { eyebrow?: string; title: string; intro: string; sections: {title:string; paragraphs:string[]}[]; }
const {eyebrow='Word Counter',title,intro,sections}=Astro.props;
---
<section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24"><p class="text-sm font-bold uppercase tracking-widest text-brand">{eyebrow}</p><h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1><p class="mt-6 text-lg leading-8 text-muted">{intro}</p><div class="mt-12 space-y-10">{sections.map(section => <section><h2 class="text-2xl font-semibold">{section.title}</h2>{section.paragraphs.map(p => <p class="mt-4 leading-7 text-body">{p}</p>)}</section>)}</div></section>
