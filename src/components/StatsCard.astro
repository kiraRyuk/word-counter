---
interface Props { label: string; valueId: string; featured?: boolean; }
const { label, valueId, featured = false } = Astro.props;
---
<article class:list={["rounded-[14px] border p-5", featured ? "border-brand bg-brand text-white" : "border-line bg-white"]}>
  <p class:list={["text-sm font-medium", featured ? "text-white/85" : "text-muted"]}>{label}</p>
  <p id={valueId} class="mt-2 text-3xl font-bold tabular-nums" aria-label={`0 ${label}`}>0</p>
</article>
