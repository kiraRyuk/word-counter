<div>
  <label for="file-upload" class="inline-flex min-h-12 cursor-pointer items-center rounded-lg border border-ink bg-white px-5 py-3 text-sm font-medium text-ink transition-colors hover:bg-soft">
    Upload .txt file
  </label>
  <input id="file-upload" type="file" accept=".txt,text/plain" class="sr-only" aria-describedby="file-help error-message" />
  <p id="file-help" class="mt-2 text-xs text-muted">Only plain-text (.txt) files are supported.</p>
</div>
